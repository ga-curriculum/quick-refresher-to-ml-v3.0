repo {
  friendlyName = "Quick Refresher for ML"
  name = "quick-refresher-to-ML-v2.0"
  type = "Lesson"
}

courses {
  new {
    name = "fallback"
    microlessons {
      mls.setup
      mls.microlesson01
      mls.microlesson02
      mls.microlesson03
      mls.microlesson04
      mls.microlesson05
    }
  }
